<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../../target/classes/advimport/schema1.xsd" save-log="true" threads-number="1">
	<mode>CREATE</mode>
	<mode>UPDATE</mode>
	<gui-parameter name="fileCI" type="FILE" title="Выберите файл (CSV)"/>
	
  	<!--  Задает метакласс импортируемых объектов  -->
	<parameter name="CIMetaClass">serviceCall$serviceCall</parameter>
	<parameter name="UUID">UUID</parameter>

	<!--  Импорт ИТ-активов  -->
	<class name="Port" threads-number="1">
		<parameter name="metaClass">${CIMetaClass}</parameter>
		
      	<csv-data-source with-header="true" file-name="${fileCI}" delimiter=";" encoding="CP1251" id-column="id">
			<column name="id" src-key="UUID"/>
			<column name="title" src-key="Title"/>
		</csv-data-source>
	
      	<constant-metaclass-resolver/>
		<object-searcher attr="${UUID}"/>

      	<attr name="${UUID}" column="id"/>
		<attr name="title" column="title"/>
	</class>
</config>